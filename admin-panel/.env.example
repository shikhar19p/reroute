# Firebase Configuration
# IMPORTANT: These values MUST match your mobile app's Firebase configuration
# Copy these values from your Firebase Console

REACT_APP_FIREBASE_API_KEY=your_firebase_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
REACT_APP_FIREBASE_APP_ID=your_firebase_app_id

# Admin Configuration
REACT_APP_ENVIRONMENT=development
REACT_APP_ADMIN_EMAIL=admin@reroute.com

# Optional: Sentry for Error Tracking
REACT_APP_SENTRY_DSN=your_sentry_dsn_here

# Optional: Analytics
REACT_APP_GOOGLE_ANALYTICS_ID=your_ga_id_here
